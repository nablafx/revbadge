% =========================================================================
% imeantit: ENVIRONMENT DEFINITION (Environment: 'imeant' -> Reference: 'highlight')
% =========================================================================
\newcounter{highlight}

% Configure cleveref to output "highlight" when referencing this counter type
\crefname{highlight}{highlight}{highlight}
\Crefname{highlight}{Highlight}{Highlights}

% --- Block Environment: imeant ---
% Named 'imeant', uses the 'highlight' counter, and registers as 'highlight' for cleveref
\newtcolorbox[use counter=highlight, crefname={highlight}{highlight}]{imeant}[3][colframe=blue, colback=blueb]{%
    enhanced, breakable, before skip=15pt, after skip=15pt,
    boxrule=0.5pt, leftrule=4pt, arc=4pt, top=12pt, bottom=10pt, left=10pt, right=10pt,
    #1, 
    attach boxed title to top left={xshift=8pt, yshift=-10pt, yshifttext=-5pt},
    fonttitle=\bfseries\small\sffamily, coltitle=white, title={#2},
    boxed title style={boxrule=0pt, arc=3pt, top=3pt, bottom=3pt, left=6pt, right=6pt, colback=tcbcolframe, colframe=tcbcolframe},
    after upper={\label{#3}} 
}

% --- Inline Macro with Highlighted Label Badge ---
\newcommand{\imeantinline}[4][colframe=blue, colback=blueb]{%
    \refstepcounter{highlight}%
    \tcbox[enhanced, on line, boxrule=0.5pt, arc=3pt, 
           top=0pt, bottom=0pt, left=0pt, right=4pt,
           boxsep=0pt, fontupper=\small, #1,
           after upper={\label{#3}}]{%
           \colorbox{tcbcolframe}{\color{white}\bfseries\sffamily\scriptsize\strut\,\,#2\,\,}\,\,\textbf{#4}%
    }%
}